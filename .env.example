OPENAI_API_KEY=your_api_key_here
HOTKEY=ctrl_l+space  # Cambiado a Ctrl + Espacio
USE_LOCAL_MODEL=false # true para usar Ollama o LM Studio
LOCAL_API_BASE=http://localhost:11434/v1 # Endpoint de Ollama (compatible con OpenAI)
RECORDING_PATH=temp_recording.wav
STT_MODEL=whisper-1
LLM_MODEL=gpt-4o-mini
# LLM Prompt for correction
CORRECTION_PROMPT="Actúa como un editor experto. Corrige la gramática, elimina muletillas y mejora la fluidez del siguiente texto transcrito. Devuelve ÚNICAMENTE el texto limpio, sin comentarios adicionales ni comillas."
